# ============================================================
# AlephFileShare — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# --- Aleph Cloud ---
# Your wallet private key used to sign Aleph messages
ALEPH_PRIVATE_KEY=0xyour_private_key_here
# Aleph API server (default is fine for most cases)
ALEPH_API_SERVER=https://api1.aleph.im
# Aleph channel used to namespace your messages
ALEPH_CHANNEL=ALEPH_FILESHARE
# Storage engine: "ipfs" or "storage"
ALEPH_STORAGE_ENGINE=ipfs

# --- Storage Mode ---
# Set to "local" for local dev (no Aleph tokens needed), "aleph" for production
STORAGE_MODE=local

# --- Backend ---
# Secret used to HMAC-sign authentication challenge tokens.
# MUST be set to a stable random string in production (same across all replicas).
# In dev, a random value is auto-generated per process start.
CHALLENGE_SECRET=change_me_to_a_64_char_hex_string
# Secret used for internal service-to-service communication
BACKEND_SECRET=change_me_to_a_random_string
# Maximum file size in bytes (default: 2GB)
MAX_FILE_SIZE_BYTES=2147483648
# Allowed MIME types (comma separated, empty = allow all)
ALLOWED_MIME_TYPES=
# CORS allowed origins (comma separated)
CORS_ORIGINS=http://localhost:3000,https://your-aleph-domain.aleph.sh

# --- Frontend ---
# Public URL of the deployed backend API
NEXT_PUBLIC_API_URL=http://localhost:8000
# WalletConnect Project ID (get one at cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
# App name shown in wallet connection dialogs
NEXT_PUBLIC_APP_NAME=AlephFileShare

# --- AI Agents ---
# LibertAI API endpoint (default Aleph-hosted LibertAI)
LIBERTAI_API_URL=https://api.libertai.io
# VirusTotal API key for the Scanner Agent
VIRUSTOTAL_API_KEY=your_virustotal_key
# LLM model to use for indexing/tagging
LLM_MODEL=mistral-7b-instruct

# --- Access Log ---
# Path to local access log file (JSONL format, local mode only)
LOCAL_ACCESS_LOG=/tmp/aleph-fileshare-access.jsonl

# --- Monitoring ---
# Optional: Webhook for Guardian Agent alerts
ALERT_WEBHOOK_URL=
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
